{
  "manifest_version": 3,
  "name": "WikiLens — Cross-Language Wikipedia",
  "version": "0.1.0",
  "description": "Read a Wikipedia article from another language edition, machine-translated, side by side — and see how each edition frames the topic.",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "wikilens@afginlabs.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "140.0"
    }
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://*.wikipedia.org/*",
    "https://translate.googleapis.com/*"
  ],
  "background": {
    "scripts": [
      "lib/browser-polyfill.js",
      "lib/cache.js",
      "lib/providers.js",
      "background.js"
    ]
  },
  "action": {
    "default_title": "WikiLens",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://*.wikipedia.org/wiki/*"],
      "js": [
        "lib/browser-polyfill.js",
        "lib/rtl.js",
        "lib/wiki.js",
        "lib/render.js",
        "lib/providers.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
